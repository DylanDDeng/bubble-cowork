{
  "name": "aegis",
  "version": "0.0.42",
  "description": "Aegis Desktop Application",
  "author": "Your Name",
  "repository": {
    "type": "git",
    "url": "https://github.com/DylanDDeng/bubble-cowork.git"
  },
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "node scripts/dev-react.mjs",
    "dev:electron": "npm run transpile:electron && node scripts/prepare-electron-native-deps.mjs && node scripts/launch-electron.mjs",
    "transpile:electron": "tsc -p src/electron/tsconfig.json",
    "build": "npm run transpile:electron && vite build",
    "test": "npm run validate:terminal && npm run check:icons && npm run verify:review-diff-panel && npm run verify:workstream-stages && npm run verify:workstream-preamble-order && npm run verify:picker-menu-side && npm run verify:git-branch-pill && npm run verify:side-chat-drop && npm run verify:opencode-sdk-adapter && npm run verify:pi-sdk-adapter && npm run verify:codex-compaction && npm run verify:spreadsheet-preview && npm run verify:claude-rewind && npm run verify:layout-tree && npm run verify:fork-session && npm run verify:composer-link-chip && npm run verify:run-group && npm run verify:subagent-workstream && npm run verify:claude-turn-latency",
    "verify:layout-tree": "node scripts/verify-layout-tree.mjs",
    "verify:subagent-workstream": "node scripts/verify-subagent-workstream.mjs",
    "verify:claude-turn-latency": "node scripts/verify-claude-turn-latency.mjs",
    "verify:codex-compaction": "npm run transpile:electron && node scripts/verify-codex-compaction.mjs",
    "verify:spreadsheet-preview": "node scripts/verify-spreadsheet-preview.mjs",
    "verify:claude-rewind": "node scripts/verify-claude-rewind.mjs",
    "verify:run-group": "node scripts/verify-run-group.mjs",
    "verify:worktree-thread-e2e": "node scripts/verify-worktree-thread-e2e.mjs",
    "verify:composer-link-chip": "node scripts/verify-composer-link-chip.mjs",
    "verify:fork-session": "node scripts/verify-fork-session.mjs",
    "verify:markdown-editor": "node scripts/verify-markdown-editor.mjs",
    "verify:review-diff-panel": "node scripts/verify-review-diff-panel.mjs",
    "verify:workstream-stages": "node scripts/verify-workstream-stages.mjs",
    "verify:workstream-preamble-order": "node scripts/verify-workstream-preamble-order.mjs",
    "verify:picker-menu-side": "node scripts/verify-picker-menu-side.mjs",
    "verify:git-branch-pill": "node scripts/verify-git-branch-pill.mjs",
    "verify:side-chat-drop": "node scripts/verify-side-chat-drop.mjs",
    "verify:opencode-sdk-adapter": "node scripts/verify-opencode-sdk-adapter.mjs",
    "verify:pi-sdk-adapter": "node scripts/verify-pi-sdk-adapter.mjs",
    "validate:terminal": "npm run transpile:electron && node scripts/prepare-electron-native-deps.mjs && node scripts/validate-terminal-runtime.cjs",
    "check:icons": "node scripts/check-ui-icon-imports.mjs",
    "build:electron": "electron-builder",
    "dist": "npm run build && npm run build:electron -- --publish never"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.197",
    "@anthropic-ai/sdk": "^0.98.0",
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
